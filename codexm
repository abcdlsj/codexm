#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_PATH="${SCRIPT_DIR}/$(basename "${BASH_SOURCE[0]}")"

PROFILE_ROOT_DEFAULT="${HOME}/.codex/profiles"
BIN_DIR_DEFAULT="${HOME}/.local/bin"
CODEX_CMD_DEFAULT="codex"
SOURCE_HOME_DEFAULT="${CODEX_HOME:-${HOME}/.codex}"
MANAGER_BIN_DEFAULT="codexm"

PROFILE_ROOT="${CODEXSWITCH_PROFILE_ROOT:-$PROFILE_ROOT_DEFAULT}"
BIN_DIR="${CODEXSWITCH_BIN_DIR:-$BIN_DIR_DEFAULT}"
CODEX_CMD="${CODEXSWITCH_CODEX_CMD:-$CODEX_CMD_DEFAULT}"
SOURCE_HOME="${CODEXSWITCH_SOURCE_HOME:-$SOURCE_HOME_DEFAULT}"
MANAGER_BIN_NAME="${CODEXSWITCH_MANAGER_BIN_NAME:-$MANAGER_BIN_DEFAULT}"

usage() {
  cat <<'EOF_USAGE'
Usage:
  codexm install [binary-name] [bin-dir]
  codexm add <profile> [command-name]
  codexm run <profile> [codex-args...]
  codexm list
  codexm path <profile>
  codexm remove <profile> [command-name]
  codexm doctor

Examples:
  ./codexm install
  codexm add work
  codexm add side-project codex-sp
  codexm run work -- --help
  codexm list

Environment variables:
  CODEXSWITCH_PROFILE_ROOT      Default: ~/.codex/profiles
  CODEXSWITCH_BIN_DIR           Default: ~/.local/bin
  CODEXSWITCH_CODEX_CMD         Default: codex
  CODEXSWITCH_SOURCE_HOME       Default: $CODEX_HOME or ~/.codex
  CODEXSWITCH_MANAGER_BIN_NAME  Default: codexm
EOF_USAGE
}

die() {
  echo "Error: $*" >&2
  exit 1
}

require_arg() {
  local value="$1"
  local name="$2"
  [[ -n "$value" ]] || die "missing argument: ${name}"
}

sanitize_name() {
  local value="$1"
  local label="$2"
  if [[ ! "$value" =~ ^[A-Za-z0-9._-]+$ ]]; then
    die "invalid ${label} '${value}'. Allowed: letters, numbers, dot, underscore, dash."
  fi
}

prompt_yes_no() {
  local question="$1"
  local default="${2:-N}"
  local answer=""
  local suffix="[y/N]"

  if [[ "$default" == "Y" ]]; then
    suffix="[Y/n]"
  fi

  while true; do
    read -r -p "${question} ${suffix} " answer
    if [[ -z "$answer" ]]; then
      answer="$default"
    fi
    answer="${answer,,}"
    case "$answer" in
      y|yes) return 0 ;;
      n|no) return 1 ;;
      *) echo "Please answer yes or no." ;;
    esac
  done
}

copy_plugin_dirs() {
  local src="$1"
  local dst="$2"
  local copied=0
  local dir=""
  local candidates=(
    "skills"
    ".skills"
    "plugins"
    ".plugins"
    ".agents"
    "agents"
    "mcp"
    ".mcp"
  )

  for dir in "${candidates[@]}"; do
    if [[ -d "${src}/${dir}" ]]; then
      mkdir -p "${dst}/${dir}"
      cp -R "${src}/${dir}/." "${dst}/${dir}/"
      copied=1
      echo "Copied plugin dir: ${dir}"
    fi
  done

  if [[ "$copied" -eq 0 ]]; then
    echo "No plugin directories found in ${src}."
  fi
}

copy_core_config() {
  local src="$1"
  local dst="$2"
  local copied=0
  local file=""
  local files=("auth.json" "config.toml")

  for file in "${files[@]}"; do
    if [[ -f "${src}/${file}" ]]; then
      cp -f "${src}/${file}" "${dst}/${file}"
      copied=1
      echo "Copied config file: ${file}"
    else
      echo "Missing config file, skipped: ${src}/${file}"
    fi
  done

  if [[ "$copied" -eq 0 ]]; then
    echo "No config files copied."
  fi
}

maybe_bootstrap_profile() {
  local profile_path="$1"

  if [[ ! -t 0 ]]; then
    return
  fi

  echo "Bootstrap options"
  echo "  source home: ${SOURCE_HOME}"
  echo "  target home: ${profile_path}"

  if prompt_yes_no "Copy plugins/skills from source home?" "N"; then
    copy_plugin_dirs "$SOURCE_HOME" "$profile_path"
  fi

  if prompt_yes_no "Copy current config (auth.json + config.toml)?" "N"; then
    copy_core_config "$SOURCE_HOME" "$profile_path"
  fi
}

cmd_install() {
  local install_name="${1:-$MANAGER_BIN_NAME}"
  local install_dir="${2:-$BIN_DIR}"
  local source="${SCRIPT_DIR}/codexm"

  sanitize_name "$install_name" "binary name"

  if [[ ! -f "$source" ]]; then
    source="$SCRIPT_PATH"
  fi

  mkdir -p "$install_dir"
  cp -f "$source" "${install_dir}/${install_name}"
  chmod +x "${install_dir}/${install_name}"

  echo "Installed: ${install_dir}/${install_name}"
  if [[ ":$PATH:" != *":${install_dir}:"* ]]; then
    echo "Note: ${install_dir} is not in PATH."
  fi
}

cmd_add() {
  local profile="${1:-}"
  require_arg "$profile" "profile"
  sanitize_name "$profile" "profile"

  local command_name="${2:-codex-${profile}}"
  local target="${BIN_DIR}/${command_name}"
  local profile_path="${PROFILE_ROOT}/${profile}"

  sanitize_name "$command_name" "command name"

  mkdir -p "$BIN_DIR" "$profile_path"

  cat >"$target" <<EOF_WRAP
#!/usr/bin/env bash
set -euo pipefail
PROFILE_ROOT="\${CODEXSWITCH_PROFILE_ROOT:-${PROFILE_ROOT}}"
CODEX_CMD="\${CODEXSWITCH_CODEX_CMD:-${CODEX_CMD}}"
export CODEX_HOME="\${PROFILE_ROOT}/${profile}"
mkdir -p "\${CODEX_HOME}"
exec "\${CODEX_CMD}" "\$@"
EOF_WRAP
  chmod +x "$target"

  maybe_bootstrap_profile "$profile_path"

  echo "Created wrapper: $target"
  echo "Profile home:    $profile_path"
  if [[ ":$PATH:" != *":${BIN_DIR}:"* ]]; then
    echo "Note: ${BIN_DIR} is not in PATH."
  fi
}

cmd_run() {
  local profile="${1:-}"
  require_arg "$profile" "profile"
  sanitize_name "$profile" "profile"
  shift || true

  local profile_path="${PROFILE_ROOT}/${profile}"
  mkdir -p "$profile_path"
  CODEX_HOME="$profile_path" exec "$CODEX_CMD" "$@"
}

cmd_list() {
  if [[ ! -d "$PROFILE_ROOT" ]]; then
    echo "(no profiles yet)"
    return
  fi

  local found=0
  while IFS= read -r name; do
    found=1
    echo "$name"
  done < <(find "$PROFILE_ROOT" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort)

  if [[ "$found" -eq 0 ]]; then
    echo "(no profiles yet)"
  fi
}

cmd_path() {
  local profile="${1:-}"
  require_arg "$profile" "profile"
  sanitize_name "$profile" "profile"
  echo "${PROFILE_ROOT}/${profile}"
}

cmd_remove() {
  local profile="${1:-}"
  require_arg "$profile" "profile"
  sanitize_name "$profile" "profile"

  local command_name="${2:-codex-${profile}}"
  local target="${BIN_DIR}/${command_name}"

  if [[ -f "$target" ]]; then
    rm -f "$target"
    echo "Removed wrapper: $target"
  else
    echo "Wrapper not found: $target"
  fi
}

cmd_doctor() {
  echo "codexm doctor"
  echo "  codex cmd:      $CODEX_CMD"
  echo "  source home:    $SOURCE_HOME"
  echo "  profile root:   $PROFILE_ROOT"
  echo "  bin dir:        $BIN_DIR"
  echo "  manager bin:    $MANAGER_BIN_NAME"
  echo "  PATH has bin?:  $([[ ":$PATH:" == *":${BIN_DIR}:"* ]] && echo yes || echo no)"

  if command -v "$CODEX_CMD" >/dev/null 2>&1; then
    echo "  codex present:  yes ($(command -v "$CODEX_CMD"))"
  else
    echo "  codex present:  no"
  fi
}

main() {
  local sub="${1:-help}"
  shift || true

  case "$sub" in
    install) cmd_install "$@" ;;
    add|create) cmd_add "$@" ;;
    run) cmd_run "$@" ;;
    list|ls) cmd_list "$@" ;;
    path) cmd_path "$@" ;;
    remove|rm) cmd_remove "$@" ;;
    doctor) cmd_doctor "$@" ;;
    help|-h|--help) usage ;;
    *)
      usage
      die "unknown subcommand: $sub"
      ;;
  esac
}

main "$@"
