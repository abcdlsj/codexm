#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_PATH="${SCRIPT_DIR}/$(basename "${BASH_SOURCE[0]}")"

PROFILE_ROOT_DEFAULT="${HOME}/.codex/profiles"
BIN_DIR_DEFAULT="${HOME}/.local/bin"
CODEX_CMD_DEFAULT="codex"
SOURCE_HOME_DEFAULT="${CODEX_HOME:-${HOME}/.codex}"
MANAGER_BIN_DEFAULT="codexm"

PROFILE_ROOT="${CODEXSWITCH_PROFILE_ROOT:-$PROFILE_ROOT_DEFAULT}"
BIN_DIR="${CODEXSWITCH_BIN_DIR:-$BIN_DIR_DEFAULT}"
CODEX_CMD="${CODEXSWITCH_CODEX_CMD:-$CODEX_CMD_DEFAULT}"
SOURCE_HOME="${CODEXSWITCH_SOURCE_HOME:-$SOURCE_HOME_DEFAULT}"
MANAGER_BIN_NAME="${CODEXSWITCH_MANAGER_BIN_NAME:-$MANAGER_BIN_DEFAULT}"

usage() {
  cat <<'EOF_USAGE'
Usage:
  codexm install [binary-name] [bin-dir]
  codexm add <profile> [command-name]
  codexm import <session-id> [target-profile|@current]
  codexm migrate session
  codexm migrate session copy <source-profile|@source> [target-profile|@current]
  codexm migrate session one <source-profile|@source> <session-id> [target-profile|@current]
  codexm run <profile> [codex-args...]
  codexm list
  codexm path <profile>
  codexm remove <profile> [command-name]
  codexm doctor

Examples:
  ./codexm install
  codexm add work
  codexm import 019d1df0-8f1e-7393-b54a-0f0b511c5a33
  codexm migrate session
  codexm migrate session copy work
  codexm migrate session one work 019d1ec4-548a-7083-992a-c807fd0b5c8e
  codexm add side-project codex-sp
  codexm run work -- --help
  codexm list

Environment variables:
  CODEXSWITCH_PROFILE_ROOT      Default: ~/.codex/profiles
  CODEXSWITCH_BIN_DIR           Default: ~/.local/bin
  CODEXSWITCH_CODEX_CMD         Default: codex
  CODEXSWITCH_SOURCE_HOME       Default: $CODEX_HOME or ~/.codex
  CODEXSWITCH_MANAGER_BIN_NAME  Default: codexm
EOF_USAGE
}

die() {
  echo "Error: $*" >&2
  exit 1
}

require_arg() {
  local value="$1"
  local name="$2"
  [[ -n "$value" ]] || die "missing argument: ${name}"
}

sanitize_name() {
  local value="$1"
  local label="$2"
  if [[ ! "$value" =~ ^[A-Za-z0-9._-]+$ ]]; then
    die "invalid ${label} '${value}'. Allowed: letters, numbers, dot, underscore, dash."
  fi
}

prompt_yes_no() {
  local question="$1"
  local default="${2:-N}"
  local answer=""
  local suffix="[y/N]"

  if [[ "$default" == "Y" ]]; then
    suffix="[Y/n]"
  fi

  while true; do
    read -r -p "${question} ${suffix} " answer
    if [[ -z "$answer" ]]; then
      answer="$default"
    fi
    answer="${answer,,}"
    case "$answer" in
      y|yes) return 0 ;;
      n|no) return 1 ;;
      *) echo "Please answer yes or no." ;;
    esac
  done
}

copy_plugin_dirs() {
  local src="$1"
  local dst="$2"
  local copied=0
  local dir=""
  local candidates=(
    "skills"
    ".skills"
    "plugins"
    ".plugins"
    ".agents"
    "agents"
    "mcp"
    ".mcp"
  )

  for dir in "${candidates[@]}"; do
    if [[ -d "${src}/${dir}" ]]; then
      mkdir -p "${dst}/${dir}"
      cp -R "${src}/${dir}/." "${dst}/${dir}/"
      copied=1
      echo "Copied plugin dir: ${dir}"
    fi
  done

  if [[ "$copied" -eq 0 ]]; then
    echo "No plugin directories found in ${src}."
  fi
}

copy_core_config() {
  local src="$1"
  local dst="$2"
  local copied=0
  local file=""
  local files=("auth.json" "config.toml")

  for file in "${files[@]}"; do
    if [[ -f "${src}/${file}" ]]; then
      cp -f "${src}/${file}" "${dst}/${file}"
      copied=1
      echo "Copied config file: ${file}"
    else
      echo "Missing config file, skipped: ${src}/${file}"
    fi
  done

  if [[ "$copied" -eq 0 ]]; then
    echo "No config files copied."
  fi
}

list_profiles() {
  if [[ ! -d "$PROFILE_ROOT" ]]; then
    return
  fi

  find "$PROFILE_ROOT" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; | sort
}

current_home() {
  if [[ -n "${CODEX_HOME:-}" ]]; then
    printf '%s\n' "$CODEX_HOME"
  else
    printf '%s\n' "$SOURCE_HOME"
  fi
}

default_source_home() {
  printf '%s\n' "${HOME}/.codex"
}

normalize_dir() {
  local dir="$1"
  [[ -d "$dir" ]] || die "directory not found: ${dir}"
  (cd "$dir" >/dev/null 2>&1 && pwd)
}

home_label() {
  local home="$1"
  local normalized_home
  normalized_home="$(normalize_dir "$home")"
  local normalized_source
  normalized_source="$(normalize_dir "$SOURCE_HOME")"
  local normalized_current
  normalized_current="$(normalize_dir "$(current_home)")"

  if [[ "$normalized_home" == "$normalized_current" ]]; then
    echo "current (${normalized_home})"
    return
  fi

  if [[ "$normalized_home" == "$normalized_source" ]]; then
    echo "source (${normalized_home})"
    return
  fi

  local profile=""
  while IFS= read -r profile; do
    if [[ -n "$profile" ]] && [[ "$normalized_home" == "$(normalize_dir "${PROFILE_ROOT}/${profile}")" ]]; then
      echo "profile:${profile} (${normalized_home})"
      return
    fi
  done < <(list_profiles)

  echo "$normalized_home"
}

resolve_home_ref() {
  local ref="${1:-@current}"

  case "$ref" in
    @source)
      printf '%s\n' "$SOURCE_HOME"
      ;;
    @current)
      current_home
      ;;
    *)
      if [[ -d "${PROFILE_ROOT}/${ref}" ]]; then
        printf '%s\n' "${PROFILE_ROOT}/${ref}"
      elif [[ -d "$ref" ]]; then
        printf '%s\n' "$ref"
      else
        die "unknown home/profile: ${ref}"
      fi
      ;;
  esac
}

prompt_select() {
  local question="$1"
  shift
  local options=("$@")
  local answer=""
  local i=0

  [[ "${#options[@]}" -gt 0 ]] || die "no selectable options for: ${question}"

  while true; do
    echo "$question" >&2
    for ((i = 0; i < ${#options[@]}; i++)); do
      echo "  $((i + 1)). ${options[$i]#*|}" >&2
    done
    read -r -p "Choose [1-${#options[@]}]: " answer >&2
    if [[ "$answer" =~ ^[0-9]+$ ]] && (( answer >= 1 && answer <= ${#options[@]} )); then
      printf '%s\n' "${options[$((answer - 1))]}"
      return 0
    fi
    echo "Please enter a valid number." >&2
  done
}

build_source_options() {
  local target_home="$1"
  local normalized_target
  normalized_target="$(normalize_dir "$target_home")"
  local normalized_source
  normalized_source="$(normalize_dir "$SOURCE_HOME")"
  local profile=""

  if [[ "$normalized_source" != "$normalized_target" ]]; then
    printf '%s\n' "@source|source home: ${normalized_source}"
  fi

  while IFS= read -r profile; do
    [[ -n "$profile" ]] || continue
    local candidate="${PROFILE_ROOT}/${profile}"
    local normalized_candidate
    normalized_candidate="$(normalize_dir "$candidate")"
    if [[ "$normalized_candidate" != "$normalized_target" ]] && [[ "$normalized_candidate" != "$normalized_source" ]]; then
      printf '%s\n' "${profile}|profile ${profile}: ${candidate}"
    fi
  done < <(list_profiles)
}

list_session_files() {
  local home="$1"
  local sessions_root="${home}/sessions"
  if [[ ! -d "$sessions_root" ]]; then
    return
  fi

  find "$sessions_root" -type f -name '*.jsonl' | sort -r
}

session_id_from_path() {
  local path="$1"
  local name
  name="$(basename "$path" .jsonl)"

  if [[ "$name" =~ ([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})$ ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi

  return 1
}

resolve_session_file() {
  local home="$1"
  local query="$2"
  local sessions_root="${home}/sessions"
  [[ -d "$sessions_root" ]] || die "session store not found: ${sessions_root}"

  if [[ -f "$query" ]]; then
    printf '%s\n' "$query"
    return 0
  fi

  if [[ -f "${sessions_root}/${query}" ]]; then
    printf '%s\n' "${sessions_root}/${query}"
    return 0
  fi

  local matches=()
  local path=""
  local session_id=""
  local rel=""
  while IFS= read -r path; do
    session_id="$(session_id_from_path "$path" || true)"
    rel="${path#${sessions_root}/}"
    if [[ "$path" == *"$query"* ]] || [[ "$rel" == *"$query"* ]] || [[ "$session_id" == "$query" ]]; then
      matches+=("$path")
    fi
  done < <(list_session_files "$home")

  if [[ "${#matches[@]}" -eq 1 ]]; then
    printf '%s\n' "${matches[0]}"
    return 0
  fi

  if [[ "${#matches[@]}" -eq 0 ]]; then
    die "session not found in $(home_label "$home"): ${query}"
  fi

  echo "Multiple sessions matched '${query}' in $(home_label "$home"):" >&2
  local idx=0
  for ((idx = 0; idx < ${#matches[@]} && idx < 10; idx++)); do
    echo "  - ${matches[$idx]#${sessions_root}/}" >&2
  done
  die "please use a more specific session id"
}

append_session_history() {
  local src_home="$1"
  local dst_home="$2"
  local session_id="$3"
  local src_history="${src_home}/history.jsonl"
  local dst_history="${dst_home}/history.jsonl"
  local line=""

  [[ -f "$src_history" ]] || return 0

  mkdir -p "$dst_home"
  touch "$dst_history"

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    if ! grep -Fqx -- "$line" "$dst_history"; then
      printf '%s\n' "$line" >>"$dst_history"
    fi
  done < <(grep -F "\"session_id\":\"${session_id}\"" "$src_history" || true)
}

copy_session_file_to_home() {
  local src_home="$1"
  local session_file="$2"
  local dst_home="$3"
  local src_sessions_root="${src_home}/sessions"
  [[ "$session_file" == "${src_sessions_root}/"* ]] || die "session file must be under ${src_sessions_root}: ${session_file}"
  local relative_path="${session_file#${src_sessions_root}/}"
  local dst_file="${dst_home}/sessions/${relative_path}"
  local session_id=""

  [[ -f "$session_file" ]] || die "session file not found: ${session_file}"

  session_id="$(session_id_from_path "$session_file" || true)"
  [[ -n "$session_id" ]] || die "failed to parse session id from: ${session_file}"

  mkdir -p "$(dirname "$dst_file")"

  if [[ -f "$dst_file" ]]; then
    if cmp -s "$session_file" "$dst_file"; then
      append_session_history "$src_home" "$dst_home" "$session_id"
      echo "Session already present, skipped file copy: ${session_id}"
      return 0
    fi
    die "target session already exists with different content: ${dst_file}"
  fi

  cp -f "$session_file" "$dst_file"
  append_session_history "$src_home" "$dst_home" "$session_id"
  echo "Copied session: ${session_id}"
}

copy_all_sessions_to_home() {
  local src_home="$1"
  local dst_home="$2"
  local session_file=""
  local copied=0

  while IFS= read -r session_file; do
    [[ -n "$session_file" ]] || continue
    copy_session_file_to_home "$src_home" "$session_file" "$dst_home"
    copied=1
  done < <(list_session_files "$src_home")

  if [[ "$copied" -eq 0 ]]; then
    echo "No sessions found in $(home_label "$src_home")."
  fi
}

interactive_pick_session_query() {
  local source_home="$1"
  local session_files=()
  local session_file=""
  local session_id=""
  local limit=20
  local answer=""
  local idx=0

  while IFS= read -r session_file; do
    session_files+=("$session_file")
  done < <(list_session_files "$source_home")

  [[ "${#session_files[@]}" -gt 0 ]] || die "no sessions found in $(home_label "$source_home")"

  echo "Recent sessions in $(home_label "$source_home"):" >&2
  for ((idx = 0; idx < ${#session_files[@]} && idx < limit; idx++)); do
    session_id="$(session_id_from_path "${session_files[$idx]}" || true)"
    echo "  $((idx + 1)). ${session_id} (${session_files[$idx]#${source_home}/sessions/})" >&2
  done

  if [[ "${#session_files[@]}" -gt "$limit" ]]; then
    echo "  Enter a full session id to pick a session outside the recent list." >&2
  fi

  while true; do
    read -r -p "Choose a session number or enter a session id: " answer >&2
    if [[ "$answer" =~ ^[0-9]+$ ]] && (( answer >= 1 && answer <= ${#session_files[@]} && answer <= limit )); then
      session_id="$(session_id_from_path "${session_files[$((answer - 1))]}" || true)"
      printf '%s\n' "$session_id"
      return 0
    fi
    if [[ -n "$answer" ]]; then
      printf '%s\n' "$answer"
      return 0
    fi
    echo "Please choose a session." >&2
  done
}

interactive_migrate_session() {
  local target_home="$1"
  mkdir -p "$target_home"

  local source_options=()
  local source_option=""
  while IFS= read -r source_option; do
    [[ -n "$source_option" ]] || continue
    source_options+=("$source_option")
  done < <(build_source_options "$target_home")

  [[ "${#source_options[@]}" -gt 0 ]] || die "no source homes available for session migration"

  echo "Session migration"
  echo "  target: $(home_label "$target_home")"

  source_option="$(prompt_select "Choose a source home:" "${source_options[@]}")"
  local source_ref="${source_option%%|*}"
  local source_home
  source_home="$(resolve_home_ref "$source_ref")"

  local mode_option
  mode_option="$(prompt_select "Choose a migration mode:" \
    "copy|copy all sessions" \
    "one|copy one session")"
  local mode="${mode_option%%|*}"

  case "$mode" in
    copy)
      copy_all_sessions_to_home "$source_home" "$target_home"
      ;;
    one)
      local session_query
      session_query="$(interactive_pick_session_query "$source_home")"
      copy_session_file_to_home "$source_home" "$(resolve_session_file "$source_home" "$session_query")" "$target_home"
      ;;
    *)
      die "unknown migration mode: ${mode}"
      ;;
  esac
}

maybe_bootstrap_profile() {
  local profile_path="$1"

  if [[ ! -t 0 ]]; then
    return
  fi

  echo "Bootstrap options"
  echo "  source home: ${SOURCE_HOME}"
  echo "  target home: ${profile_path}"

  if prompt_yes_no "Copy plugins/skills from source home?" "N"; then
    copy_plugin_dirs "$SOURCE_HOME" "$profile_path"
  fi

  if prompt_yes_no "Copy current config (auth.json + config.toml)?" "N"; then
    copy_core_config "$SOURCE_HOME" "$profile_path"
  fi

  if prompt_yes_no "Migrate sessions into this profile?" "N"; then
    interactive_migrate_session "$profile_path"
  fi
}

cmd_install() {
  local install_name="${1:-$MANAGER_BIN_NAME}"
  local install_dir="${2:-$BIN_DIR}"
  local source="${SCRIPT_DIR}/codexm"

  sanitize_name "$install_name" "binary name"

  if [[ ! -f "$source" ]]; then
    source="$SCRIPT_PATH"
  fi

  mkdir -p "$install_dir"
  cp -f "$source" "${install_dir}/${install_name}"
  chmod +x "${install_dir}/${install_name}"

  echo "Installed: ${install_dir}/${install_name}"
  if [[ ":$PATH:" != *":${install_dir}:"* ]]; then
    echo "Note: ${install_dir} is not in PATH."
  fi
}

cmd_add() {
  local profile="${1:-}"
  require_arg "$profile" "profile"
  sanitize_name "$profile" "profile"

  local command_name="${2:-codex-${profile}}"
  local target="${BIN_DIR}/${command_name}"
  local profile_path="${PROFILE_ROOT}/${profile}"

  sanitize_name "$command_name" "command name"

  mkdir -p "$BIN_DIR" "$profile_path"

  cat >"$target" <<EOF_WRAP
#!/usr/bin/env bash
set -euo pipefail
PROFILE_ROOT="\${CODEXSWITCH_PROFILE_ROOT:-${PROFILE_ROOT}}"
CODEX_CMD="\${CODEXSWITCH_CODEX_CMD:-${CODEX_CMD}}"
export CODEX_HOME="\${PROFILE_ROOT}/${profile}"
mkdir -p "\${CODEX_HOME}"
exec "\${CODEX_CMD}" "\$@"
EOF_WRAP
  chmod +x "$target"

  maybe_bootstrap_profile "$profile_path"

  echo "Created wrapper: $target"
  echo "Profile home:    $profile_path"
  if [[ ":$PATH:" != *":${BIN_DIR}:"* ]]; then
    echo "Note: ${BIN_DIR} is not in PATH."
  fi
}

cmd_run() {
  local profile="${1:-}"
  require_arg "$profile" "profile"
  sanitize_name "$profile" "profile"
  shift || true

  local profile_path="${PROFILE_ROOT}/${profile}"
  mkdir -p "$profile_path"
  CODEX_HOME="$profile_path" exec "$CODEX_CMD" "$@"
}

cmd_list() {
  if [[ ! -d "$PROFILE_ROOT" ]]; then
    echo "(no profiles yet)"
    return
  fi

  local found=0
  while IFS= read -r name; do
    found=1
    echo "$name"
  done < <(list_profiles)

  if [[ "$found" -eq 0 ]]; then
    echo "(no profiles yet)"
  fi
}

cmd_path() {
  local profile="${1:-}"
  require_arg "$profile" "profile"
  sanitize_name "$profile" "profile"
  echo "${PROFILE_ROOT}/${profile}"
}

cmd_remove() {
  local profile="${1:-}"
  require_arg "$profile" "profile"
  sanitize_name "$profile" "profile"

  local command_name="${2:-codex-${profile}}"
  local target="${BIN_DIR}/${command_name}"

  if [[ -f "$target" ]]; then
    rm -f "$target"
    echo "Removed wrapper: $target"
  else
    echo "Wrapper not found: $target"
  fi
}

cmd_doctor() {
  echo "codexm doctor"
  echo "  codex cmd:      $CODEX_CMD"
  echo "  source home:    $SOURCE_HOME"
  echo "  profile root:   $PROFILE_ROOT"
  echo "  bin dir:        $BIN_DIR"
  echo "  manager bin:    $MANAGER_BIN_NAME"
  echo "  PATH has bin?:  $([[ ":$PATH:" == *":${BIN_DIR}:"* ]] && echo yes || echo no)"

  if command -v "$CODEX_CMD" >/dev/null 2>&1; then
    echo "  codex present:  yes ($(command -v "$CODEX_CMD"))"
  else
    echo "  codex present:  no"
  fi
}

cmd_migrate_session() {
  local action="${1:-interactive}"
  shift || true

  case "$action" in
    interactive)
      [[ -t 0 ]] || die "interactive session migration requires a TTY"
      interactive_migrate_session "$(resolve_home_ref "@current")"
      ;;
    copy|all)
      local source_ref="${1:-@source}"
      local target_ref="${2:-@current}"
      local source_home
      local target_home
      source_home="$(resolve_home_ref "$source_ref")"
      target_home="$(resolve_home_ref "$target_ref")"
      mkdir -p "$target_home"
      copy_all_sessions_to_home "$source_home" "$target_home"
      ;;
    one|single)
      local source_ref="${1:-}"
      local session_query="${2:-}"
      local target_ref="${3:-@current}"
      require_arg "$source_ref" "source-profile|@source"
      require_arg "$session_query" "session-id"
      local source_home
      local target_home
      source_home="$(resolve_home_ref "$source_ref")"
      target_home="$(resolve_home_ref "$target_ref")"
      mkdir -p "$target_home"
      copy_session_file_to_home "$source_home" "$(resolve_session_file "$source_home" "$session_query")" "$target_home"
      ;;
    *)
      die "unknown migrate session action: ${action}"
      ;;
  esac
}

cmd_migrate() {
  local subject="${1:-}"
  shift || true

  case "$subject" in
    session|sessions|"")
      cmd_migrate_session "$@"
      ;;
    *)
      die "unknown migrate target: ${subject}"
      ;;
  esac
}

cmd_import() {
  local session_query="${1:-}"
  local target_ref="${2:-@current}"
  require_arg "$session_query" "session-id"

  local source_home
  local target_home
  source_home="$(default_source_home)"
  [[ -d "$source_home" ]] || die "default source home not found: ${source_home}"
  target_home="$(resolve_home_ref "$target_ref")"
  mkdir -p "$target_home"

  copy_session_file_to_home "$source_home" "$(resolve_session_file "$source_home" "$session_query")" "$target_home"
}

main() {
  local sub="${1:-help}"
  shift || true

  case "$sub" in
    install) cmd_install "$@" ;;
    add|create) cmd_add "$@" ;;
    import|import-session) cmd_import "$@" ;;
    migrate) cmd_migrate "$@" ;;
    run) cmd_run "$@" ;;
    list|ls) cmd_list "$@" ;;
    path) cmd_path "$@" ;;
    remove|rm) cmd_remove "$@" ;;
    doctor) cmd_doctor "$@" ;;
    help|-h|--help) usage ;;
    *)
      usage
      die "unknown subcommand: $sub"
      ;;
  esac
}

main "$@"
